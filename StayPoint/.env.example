# Copy to .env and fill in your local values. The .env file is gitignored.

# Database
DB_URL=jdbc:mysql://localhost:3306/staypoint_db
DB_USERNAME=root
DB_PASSWORD=

# Server
SERVER_PORT=1004

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# JWT
JWT_SECRET=
JWT_EXPIRATION_MS=86400000

# Cloudinary (image uploads) — get these from your Cloudinary dashboard
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=staypoint/pgs
