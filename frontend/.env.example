# Base URL the frontend uses for API calls.
# In dev, leave as /api — Vite proxies /api -> http://localhost:1004 (see vite.config.js),
# so there are no CORS issues. For a deployed build, set this to the backend's full URL,
# e.g. https://staypoint-api.onrender.com/api
VITE_API_BASE_URL=/api

# Clerk auth — Publishable key from the Clerk dashboard (starts with pk_test_ or pk_live_)
VITE_CLERK_PUBLISHABLE_KEY=
